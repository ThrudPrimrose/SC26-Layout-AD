# -----------------------------------------------------------------------------
# SC26-Layout-AD -- repository-wide gitignore
#
# Keep a directory (like results/) while ignoring its contents? Commit a
# `.gitkeep` in it and un-ignore that placeholder with `!<path>/.gitkeep`.
# -----------------------------------------------------------------------------

# ---- Build artifacts -------------------------------------------------------
*.o
*.obj
*.a
*.lo
*.so
*.dylib
*.out

# Per-experiment compiled bench binaries (run scripts write them into the
# experiment root as `bench_cpu`, `bench_gpu`, `conjugate_{cpu,gpu}_*`, etc.)
Experiments/*/bench_cpu
Experiments/*/bench_gpu
Experiments/*/bench_gpu_a
Experiments/*/bench_cpu_a
Experiments/*/bench_stream_cpu
Experiments/*/bench_stream_gpu
Experiments/*/cost_metrics
Experiments/E6_VelocityTendencies/*/bench_cpu
Experiments/E6_VelocityTendencies/*/bench_gpu
Experiments/E6_VelocityTendencies/*/bench_gpu_a
Experiments/E6_VelocityTendencies/*/bench_cpu_a
Experiments/E6_VelocityTendencies/*/bench_gpu_oldstyle
Experiments/E6_VelocityTendencies/*/bench_stream_cpu
Experiments/E6_VelocityTendencies/*/bench_stream_gpu
Experiments/E6_VelocityTendencies/*/cost_metrics
Experiments/E2_Conjugation/conjugate_cpu_*
Experiments/E2_Conjugation/conjugate_gpu_*
Experiments/E4_GAS/zaxpy_cpu
Experiments/E4_GAS/zaxpy_gpu
Experiments/E5_USXX/addusxx_cpu
Experiments/E5_USXX/addusxx_gpu
Experiments/E3_Transpose/transpose_cpu
Experiments/E3_Transpose/transpose_gpu
Experiments/E3_Transpose/transpose_hptt
Experiments/E3_Transpose/transpose_lib
# E7 compiles per-config velocity-tendencies binaries plus per-stage
# pipeline binaries (velocity_stage1..4 + one velocity_stage5a_<config>
# per layout config in CONFIGS). They land in the experiment root next
# to main.cpp -- O(MB) each, never tracked.
Experiments/E7_FullVelocityTendencies/velocity_stage*
Experiments/E7_FullVelocityTendencies/main.o
Experiments/E7_FullVelocityTendencies/main

# ---- Per-experiment results directories (CSV output of runs) ---------------
Experiments/*/results/
Experiments/E6_VelocityTendencies/*/results/

# ---- Per-experiment local data directories (downloaded payloads) -----------
# data_r02b05/ is the ICON dataset; data_<resolution>/ generalises in case
# higher-resolution variants (R02B06, etc.) get added later. Always
# user-provided via tools/download_data.sh.
Experiments/*/data_r02b05/
Experiments/*/data_*/

# ---- Downloaded / generated data -------------------------------------------
Experiments/E4_GAS/bin/
Experiments/E5_USXX/bin/
# Binary data payloads (QE/ICON index maps, etc.) fetched via download_data.sh
*.bin
# Any archive payload -- never commit, always fetch via download_data.sh
*.zip
*.tar
*.tar.gz
*.tgz
*.tar.bz2
*.tbz2
*.tar.xz
*.txz
*.tar.zst
*.tzst
*.7z
*.rar
*.gz
*.bz2
*.xz
*.zst
# ICON R02B05 data is user-provided (see Experiments/E6_*/README.md)
Experiments/E6_VelocityTendencies/data_r02b05/

# ---- Python ----------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
**/.pytest_cache/

# ---- venv (any name) -------------------------------------------------------
# Catches venv/, .venv/, venv-old/, venv.pyenv-backup/, .venv.new/, etc.
# venv directories can be hundreds of MB of site-packages — never commit.
venv*/
.venv*/
Experiments/common/dace/
# Transient: get-pip.py gets dropped here during bootstrap (setup.sh cleans it).
Experiments/common/.get-pip.py

# ---- Logs (SLURM stray, pip, build, session helpers, ...) ------------------
*.log

# ---- Core dumps (cluster names them core_nid<host>_<pid>) ------------------
core
core.*
core_*
nid*

# ---- LaTeX build artifacts (capital-L: folder was renamed from latex/) -----
Latex/*.aux
Latex/*.log
Latex/*.out
Latex/*.bbl
Latex/*.blg
Latex/*.fdb_latexmk
Latex/*.fls
Latex/*.synctex.gz
Latex/*.toc
Latex/*.nav
Latex/*.snm
Latex/*.xdv
Latex/*.auxlock
# The committed PDF is the built AD; keep it tracked.
# If a reviewer rebuilds, the new PDF will diff against the tracked one.
# To always ignore: uncomment the next line.
# Latex/*.pdf

# ---- Editor / OS scratch ---------------------------------------------------
.DS_Store
.vscode/
.idea/
*.swp
*.swo
*~
.cache/

# ---- DaCe scratch ----------------------------------------------------------
.dacecache/
*.sdfg.cache/
